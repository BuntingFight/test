		topts = topts or {}
		local tname = topts.name or "toggle"
		local default = topts.default or false
		local side = topts.side or "left"
		local callback = topts.callback or function() end
		local target_parent = side == "right" and right_col or left_col

		local state = default
		local accent_color = Color3.fromRGB(59, 130, 246)

		local row = new_inst("Frame", {
			BackgroundColor3 = Color3.fromRGB(25, 25, 25),
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 30),
			ZIndex = 4,
			Parent = target_parent,
		})
		new_inst("UICorner", { CornerRadius = UDim.new(0, 6), Parent = row })
		new_inst("UIStroke", { Color = Color3.fromRGB(40, 40, 40), Thickness = 1, Parent = row })

		local label = new_inst("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 10, 0, 0),
			Size = UDim2.new(1, -55, 1, 0),
			Font = Enum.Font.Gotham,
			Text = tname,
			TextColor3 = Color3.fromRGB(200, 200, 200),
			TextSize = 11,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 5,
			Parent = row,
		})

		local track_bg = new_inst("Frame", {
			BackgroundColor3 = Color3.fromRGB(45, 45, 45),
			BorderSizePixel = 0,
			Position = UDim2.new(1, -40, 0.5, -8),
			Size = UDim2.new(0, 30, 0, 16),
			ZIndex = 5,
			Parent = row,
		})
		new_inst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track_bg })

		local thumb = new_inst("Frame", {
			BackgroundColor3 = Color3.fromRGB(160, 160, 160),
			BorderSizePixel = 0,
			Position = UDim2.new(0, 2, 0.5, -6),
			Size = UDim2.new(0, 12, 0, 12),
			ZIndex = 6,
			Parent = track_bg,
		})
		new_inst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumb })

		local function update_visual(animated)
			local dur = animated and 0.25 or 0
			if state then
				tween(track_bg, { BackgroundColor3 = accent_color }, dur)
				tween(thumb, { Position = UDim2.new(0, 16, 0.5, -6), BackgroundColor3 = Color3.fromRGB(255, 255, 255) }, dur)
			else
				tween(track_bg, { BackgroundColor3 = Color3.fromRGB(45, 45, 45) }, dur)
				tween(thumb, { Position = UDim2.new(0, 2, 0.5, -6), BackgroundColor3 = Color3.fromRGB(160, 160, 160) }, dur)
			end
		end

		update_visual(false)

		local click_area = new_inst("TextButton", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 1, 0),
			Text = "",
			ZIndex = 7,
			Parent = row,
		})
		click_area.MouseButton1Click:Connect(function()
			state = not state
			update_visual(true)
			callback(state)
		end)

		return {
			set_state = function(_, s)
				state = s
				update_visual(true)
				callback(state)
			end,
			get_state = function() return state end,
		}
	end

	function tab_obj:slider(sopts)
		sopts = sopts or {}
		local sname = sopts.name or "slider"
		local min_val = sopts.min or 0
		local max_val = sopts.max or 100
		local default = sopts.default or min_val
		local suffix = sopts.suffix or ""
		local side = sopts.side or "left"
		local callback = sopts.callback or function() end
		local target_parent = side == "right" and right_col or left_col

		local value = math.clamp(default, min_val, max_val)
		local accent_color = Color3.fromRGB(59, 130, 246)

		local row = new_inst("Frame", {
			BackgroundColor3 = Color3.fromRGB(25, 25, 25),
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 42),
			ZIndex = 4,
			Parent = target_parent,
		})
		new_inst("UICorner", { CornerRadius = UDim.new(0, 6), Parent = row })
		new_inst("UIStroke", { Color = Color3.fromRGB(40, 40, 40), Thickness = 1, Parent = row })

		local name_label = new_inst("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 10, 0, 4),
			Size = UDim2.new(0.6, 0, 0, 16),
			Font = Enum.Font.Gotham,
			Text = sname,
			TextColor3 = Color3.fromRGB(200, 200, 200),
			TextSize = 11,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 5,
			Parent = row,
		})

		local val_label = new_inst("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(1, -50, 0, 4),
			Size = UDim2.new(0, 40, 0, 16),
			Font = Enum.Font.GothamBold,
			Text = tostring(value) .. suffix,
			TextColor3 = accent_color,
			TextSize = 11,
			TextXAlignment = Enum.TextXAlignment.Right,
			ZIndex = 5,
			Parent = row,
		})

		local track_bg = new_inst("Frame", {
			BackgroundColor3 = Color3.fromRGB(40, 40, 40),
			BorderSizePixel = 0,
			Position = UDim2.new(0, 10, 0, 26),
			Size = UDim2.new(1, -20, 0, 4),
			ZIndex = 5,
			Parent = row,
		})
		new_inst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track_bg })

		local track_fill = new_inst("Frame", {
			BackgroundColor3 = accent_color,
			BorderSizePixel = 0,
			Size = UDim2.new(0, 0, 1, 0),
			ZIndex = 6,
			Parent = track_bg,
		})
		new_inst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track_fill })

		local thumb_frame = new_inst("Frame", {
			BackgroundColor3 = Color3.fromRGB(255, 255, 255),
			BorderSizePixel = 0,
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0, 0, 0.5, 0),
			Size = UDim2.new(0, 10, 0, 10),
			ZIndex = 7,
			Parent = track_bg,
		})
		new_inst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumb_frame })

		local function update_slider(frac, animated)
			frac = math.clamp(frac, 0, 1)
			value = math.floor(min_val + frac * (max_val - min_val))
			local dur = animated and 0.12 or 0
			tween(track_fill, { Size = UDim2.new(frac, 0, 1, 0) }, dur)
			tween(thumb_frame, { Position = UDim2.new(frac, 0, 0.5, 0) }, dur)
			val_label.Text = tostring(value) .. suffix
			callback(value)
		end

		update_slider((value - min_val) / (max_val - min_val), false)

		local dragging_slider = false
		local click_btn = new_inst("TextButton", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, -5, 0, -5),
			Size = UDim2.new(1, 10, 1, 10),
			Text = "",
			ZIndex = 8,
			Parent = track_bg,
		})

		click_btn.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging_slider = true
				tween(thumb_frame, { Size = UDim2.new(0, 12, 0, 12) }, 0.1)
			end
		end)
		user_input_service.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 and dragging_slider then
				dragging_slider = false
				tween(thumb_frame, { Size = UDim2.new(0, 10, 0, 10) }, 0.15)
			end
		end)
		user_input_service.InputChanged:Connect(function(inp)
			if dragging_slider and inp.UserInputType == Enum.UserInputType.MouseMovement then
				local track_pos = track_bg.AbsolutePosition
				local track_size = track_bg.AbsoluteSize
				local rel_x = inp.Position.X - track_pos.X
				local frac = rel_x / track_size.X
				update_slider(frac, false)
			end
		end)

		return {
			set_value = function(_, v)
				update_slider((v - min_val) / (max_val - min_val), true)
			end,
			get_value = function() return value end,
		}
	end

	return tab_obj
end

function window_mt:destroy()
	if self.screen_gui then
		self.screen_gui:Destroy()
	end
end

return ui
