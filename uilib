function PrnxUI.Notify(opts)
	opts = opts or {}
	local title = opts.Title or "Notification"
	local text = opts.Text or ""
	local duration = opts.Duration or 4
	local color = opts.Color or Color3.fromRGB(59, 130, 246)

	ensureNotifContainer()

	local card = newInst("Frame", {
		Name = "Notif",
		BackgroundColor3 = Color3.fromRGB(22, 22, 22),
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 72),
		Position = UDim2.new(1, 40, 0, 0),
		ClipsDescendants = true,
		Parent = notifContainer,
	})
	newInst("UICorner", { CornerRadius = UDim.new(0, 10), Parent = card })
	newInst("UIStroke", { Color = Color3.fromRGB(50, 50, 50), Thickness = 1, Parent = card })

	-- shadow
	local shadow = newInst("ImageLabel", {
		BackgroundTransparency = 1,
		Image = "rbxassetid://6014261993",
		ImageColor3 = Color3.new(0, 0, 0),
		ImageTransparency = 0.5,
		Position = UDim2.new(0, -8, 0, -8),
		Size = UDim2.new(1, 16, 1, 16),
		ZIndex = 0,
		Parent = card,
	})

	-- progress bar bg
	local progressBg = newInst("Frame", {
		BackgroundColor3 = Color3.fromRGB(35, 35, 35),
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0, 0),
		Size = UDim2.new(1, 0, 0, 3),
		ZIndex = 3,
		Parent = card,
	})
	newInst("UICorner", { CornerRadius = UDim.new(0, 2), Parent = progressBg })

	local progressFill = newInst("Frame", {
		BackgroundColor3 = color,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0, 0),
		Size = UDim2.new(1, 0, 1, 0),
		ZIndex = 4,
		Parent = progressBg,
	})
	newInst("UICorner", { CornerRadius = UDim.new(0, 2), Parent = progressFill })

	-- timer label top right
	local timerLabel = newInst("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(1, -50, 0, 5),
		Size = UDim2.new(0, 44, 0, 16),
		Font = Enum.Font.GothamBold,
		Text = string.format("%.1fs", duration),
		TextColor3 = Color3.fromRGB(120, 120, 120),
		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Right,
		ZIndex = 5,
		Parent = card,
	})

	-- title
	local titleLabel = newInst("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 14, 0, 8),
		Size = UDim2.new(1, -70, 0, 20),
		Font = Enum.Font.GothamBold,
		Text = title,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 5,
		Parent = card,
	})

	-- divider
	local divider = newInst("Frame", {
		BackgroundColor3 = color,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 14, 0, 30),
		Size = UDim2.new(0, 2, 0, 30),
		ZIndex = 5,
		Parent = card,
	})
	newInst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = divider })

	-- text
	local textLabel = newInst("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 22, 0, 30),
		Size = UDim2.new(1, -36, 0, 32),
		Font = Enum.Font.Gotham,
		Text = text,
		TextColor3 = Color3.fromRGB(160, 160, 160),
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		TextWrapped = true,
		ZIndex = 5,
		Parent = card,
	})

	-- slide in
	tween(card, { Position = UDim2.new(0, 0, 0, 0) }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

	-- countdown
	local elapsed = 0
	local conn
	conn = RunService.Heartbeat:Connect(function(dt)
		elapsed = elapsed + dt
		local remaining = math.max(0, duration - elapsed)
		local frac = remaining / duration
		timerLabel.Text = string.format("%.1fs", remaining)
		progressFill.Size = UDim2.new(frac, 0, 1, 0)

		if elapsed >= duration then
			conn:Disconnect()
			tween(card, { Position = UDim2.new(1, 40, 0, 0) }, 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
			task.delay(0.35, function()
				tween(card, { Size = UDim2.new(1, 0, 0, 0) }, 0.2)
				task.delay(0.22, function()
					card:Destroy()
				end)
			end)
		end
	end)
end

