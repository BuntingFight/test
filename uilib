		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0, 0),
		Size = UDim2.new(1, 0, 1, 0),
		ZIndex = 4,
		Parent = progress_bg,
	})
	new_inst("UICorner", { CornerRadius = UDim.new(0, 2), Parent = progress_fill })

	local timer_label = new_inst("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(1, -45, 0, 5),
		Size = UDim2.new(0, 40, 0, 14),
		Font = Enum.Font.GothamBold,
		Text = string.format("%.1fs", duration),
		TextColor3 = Color3.fromRGB(120, 120, 120),
		TextSize = 10,
		TextXAlignment = Enum.TextXAlignment.Right,
		ZIndex = 5,
		Parent = card,
	})

	local title_label = new_inst("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 12, 0, 6),
		Size = UDim2.new(1, -60, 0, 18),
		Font = Enum.Font.GothamBold,
		Text = title,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 5,
		Parent = card,
	})

	local divider = new_inst("Frame", {
		BackgroundColor3 = color,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 12, 0, 26),
		Size = UDim2.new(0, 2, 0, 28),
		ZIndex = 5,
		Parent = card,
	})
	new_inst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = divider })

	local text_label = new_inst("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 20, 0, 26),
		Size = UDim2.new(1, -32, 0, 28),
		Font = Enum.Font.Gotham,
		Text = text,
		TextColor3 = Color3.fromRGB(160, 160, 160),
		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		TextWrapped = true,
		ZIndex = 5,
		Parent = card,
	})

	tween(card, { Position = UDim2.new(0, 0, 0, 0) }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

	local elapsed = 0
	local conn
	conn = run_service.Heartbeat:Connect(function(dt)
		elapsed = elapsed + dt
		local remaining = math.max(0, duration - elapsed)
		local frac = remaining / duration
		timer_label.Text = string.format("%.1fs", remaining)
		progress_fill.Size = UDim2.new(frac, 0, 1, 0)

		if elapsed >= duration then
			conn:Disconnect()
			tween(card, { Position = UDim2.new(1, 40, 0, 0) }, 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
			task.delay(0.35, function()
				tween(card, { Size = UDim2.new(1, 0, 0, 0) }, 0.2)
				task.delay(0.22, function()
					card:Destroy()
				end)
			end)
		end
	end)
end

