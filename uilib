			Parent = trackBg,
		})
		newInst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = trackFill })

		local thumbFrame = newInst("Frame", {
			BackgroundColor3 = Color3.fromRGB(255, 255, 255),
			BorderSizePixel = 0,
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0, 0, 0.5, 0),
			Size = UDim2.new(0, 14, 0, 14),
			ZIndex = 7,
			Parent = trackBg,
		})
		newInst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumbFrame })

		-- glow on thumb
		local glow = newInst("ImageLabel", {
			BackgroundTransparency = 1,
			Image = "rbxassetid://6014261993",
			ImageColor3 = accentColor,
			ImageTransparency = 0.6,
			Position = UDim2.new(0.5, -12, 0.5, -12),
			Size = UDim2.new(0, 24, 0, 24),
			ZIndex = 6,
			Parent = thumbFrame,
		})

		local function updateSlider(frac, animated)
			frac = math.clamp(frac, 0, 1)
			value = math.floor(min + frac * (max - min))
			local dur = animated and 0.12 or 0
			tween(trackFill, { Size = UDim2.new(frac, 0, 1, 0) }, dur)
			tween(thumbFrame, { Position = UDim2.new(frac, 0, 0.5, 0) }, dur)
			valLabel.Text = tostring(value) .. suffix
			callback(value)
		end

		-- init
		updateSlider((value - min) / (max - min), false)

		local draggingSlider = false
		local clickBtn = newInst("TextButton", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, -7, 0, -7),
			Size = UDim2.new(1, 14, 1, 14),
			Text = "",
			ZIndex = 8,
			Parent = trackBg,
		})

		clickBtn.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then
				draggingSlider = true
				tween(thumbFrame, { Size = UDim2.new(0, 16, 0, 16) }, 0.1)
				tween(glow, { ImageTransparency = 0.3 }, 0.1)
			end
		end)
		UserInputService.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 and draggingSlider then
				draggingSlider = false
				tween(thumbFrame, { Size = UDim2.new(0, 14, 0, 14) }, 0.15)
				tween(glow, { ImageTransparency = 0.6 }, 0.15)
			end
		end)
		UserInputService.InputChanged:Connect(function(inp)
			if draggingSlider and inp.UserInputType == Enum.UserInputType.MouseMovement then
				local trackPos = trackBg.AbsolutePosition
				local trackSize = trackBg.AbsoluteSize
				local relX = inp.Position.X - trackPos.X
				local frac = relX / trackSize.X
				updateSlider(frac, false)
			end
		end)

		return {
			SetValue = function(_, v)
				updateSlider((v - min) / (max - min), true)
			end,
			GetValue = function() return value end,
		}
	end

	return tab
end

function Window:Destroy()
	if self._sg then
		self._sg:Destroy()
	end
end

return PrnxUI
