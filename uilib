	local content = newInst("Frame", {
		Name = "Content",
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 0, 0, 78),
		Size = UDim2.new(1, 0, 1, -78),
		ZIndex = 2,
		Parent = main,
	})
	self._content = content
	self._tabBar = tabScroll

	-- dragging
	local dragging, dragStart, startPos = false, nil, nil
	header.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = inp.Position
			startPos = main.Position
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = inp.Position - dragStart
			local target = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
			tween(main, { Position = target }, 0.07, Enum.EasingStyle.Linear)
		end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	-- appear animation
	main.Size = UDim2.new(0, self.Size.X.Offset * 0.92, 0, self.Size.Y.Offset * 0.92)
	main.BackgroundTransparency = 1
	tween(main, {
		Size = self.Size,
		BackgroundTransparency = 0,
	}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

	return self
end

function Window:Tab(opts)
	opts = opts or {}
	local name = opts.Name or "Tab"

	local tab = {}
	tab._elements = {}

	local tabBtn = newInst("TextButton", {
		BackgroundColor3 = Color3.fromRGB(30, 30, 30),
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, -8),
		AutomaticSize = Enum.AutomaticSize.X,
		Font = Enum.Font.GothamSemibold,
		Text = "",
		ZIndex = 4,
		Parent = self._tabBar,
	})
	newInst("UICorner", { CornerRadius = UDim.new(0, 7), Parent = tabBtn })
	newInst("UIPadding", {
		PaddingLeft = UDim.new(0, 14),
		PaddingRight = UDim.new(0, 14),
		Parent = tabBtn,
	})

	local tabLabel = newInst("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = name,
		TextColor3 = Color3.fromRGB(100, 100, 100),
		TextSize = 12,
		ZIndex = 5,
		Parent = tabBtn,
	})

	-- scroll frame for elements
	local page = newInst("ScrollingFrame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0, 0),
		Size = UDim2.new(1, 0, 1, 0),
		CanvasSize = UDim2.new(0, 0, 0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		ScrollBarThickness = 3,
		ScrollBarImageColor3 = Color3.fromRGB(59, 130, 246),
		Visible = false,
		ZIndex = 3,
		Parent = self._content,
	})
	newInst("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 6),
		Parent = page,
	})
	newInst("UIPadding", {
		PaddingTop = UDim.new(0, 10),
		PaddingLeft = UDim.new(0, 12),
		PaddingRight = UDim.new(0, 12),
		PaddingBottom = UDim.new(0, 10),
		Parent = page,
	})

	tab._btn = tabBtn
	tab._label = tabLabel
	tab._page = page
	tab._window = self

	local function activate()
		-- deactivate others
		for _, t in ipairs(self._tabs) do
			t._page.Visible = false
			tween(t._btn, { BackgroundColor3 = Color3.fromRGB(30, 30, 30) }, 0.2)
			tween(t._label, { TextColor3 = Color3.fromRGB(100, 100, 100) }, 0.2)
		end
		page.Visible = true
		tween(tabBtn, { BackgroundColor3 = Color3.fromRGB(40, 40, 40) }, 0.2)
		tween(tabLabel, { TextColor3 = Color3.fromRGB(255, 255, 255) }, 0.2)
		self._activeTab = tab
	end

	tabBtn.MouseButton1Click:Connect(activate)

	-- hover
	tabBtn.MouseEnter:Connect(function()
		if self._activeTab ~= tab then
			tween(tabBtn, { BackgroundColor3 = Color3.fromRGB(35, 35, 35) }, 0.15)
			tween(tabLabel, { TextColor3 = Color3.fromRGB(160, 160, 160) }, 0.15)
		end
	end)
	tabBtn.MouseLeave:Connect(function()
		if self._activeTab ~= tab then
			tween(tabBtn, { BackgroundColor3 = Color3.fromRGB(30, 30, 30) }, 0.15)
			tween(tabLabel, { TextColor3 = Color3.fromRGB(100, 100, 100) }, 0.15)
		end
	end)

	table.insert(self._tabs, tab)

	-- auto-select first tab
	if #self._tabs == 1 then
		activate()
	end

	-- elements API
	function tab:Button(bopts)
		bopts = bopts or {}
		local bname = bopts.Name or "Button"
		local callback = bopts.Callback or function() end

		local row = newInst("Frame", {
			BackgroundColor3 = Color3.fromRGB(30, 30, 30),
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 38),
			ZIndex = 4,
			Parent = page,
		})
		newInst("UICorner", { CornerRadius = UDim.new(0, 8), Parent = row })
		newInst("UIStroke", { Color = Color3.fromRGB(45, 45, 45), Thickness = 1, Parent = row })

		local btn = newInst("TextButton", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 1, 0),
			Font = Enum.Font.GothamSemibold,
			Text = bname,
			TextColor3 = Color3.fromRGB(220, 220, 220),
			TextSize = 13,
			ZIndex = 5,
			Parent = row,
		})

		btn.MouseEnter:Connect(function()
			tween(row, { BackgroundColor3 = Color3.fromRGB(38, 38, 38) }, 0.15)
		end)
		btn.MouseLeave:Connect(function()
			tween(row, { BackgroundColor3 = Color3.fromRGB(30, 30, 30) }, 0.15)
		end)
		btn.MouseButton1Down:Connect(function()
			tween(row, { BackgroundColor3 = Color3.fromRGB(22, 22, 22) }, 0.08)
		end)
		btn.MouseButton1Up:Connect(function()
			tween(row, { BackgroundColor3 = Color3.fromRGB(38, 38, 38) }, 0.15)
		end)
		btn.MouseButton1Click:Connect(function()
			callback()
		end)

		return row
	end

	function tab:Toggle(topts)
		topts = topts or {}
		local tname = topts.Name or "Toggle"
		local default = topts.Default or false
		local callback = topts.Callback or function() end

		local state = default
		local accentColor = Color3.fromRGB(59, 130, 246)

		local row = newInst("Frame", {
			BackgroundColor3 = Color3.fromRGB(30, 30, 30),
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 38),
			ZIndex = 4,
			Parent = page,
		})
		newInst("UICorner", { CornerRadius = UDim.new(0, 8), Parent = row })
		newInst("UIStroke", { Color = Color3.fromRGB(45, 45, 45), Thickness = 1, Parent = row })

		local label = newInst("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 14, 0, 0),
			Size = UDim2.new(1, -70, 1, 0),
			Font = Enum.Font.Gotham,
			Text = tname,
			TextColor3 = Color3.fromRGB(200, 200, 200),
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 5,
			Parent = row,
		})

		local trackBg = newInst("Frame", {
			BackgroundColor3 = Color3.fromRGB(50, 50, 50),
			BorderSizePixel = 0,
			Position = UDim2.new(1, -52, 0.5, -10),
			Size = UDim2.new(0, 38, 0, 20),
			ZIndex = 5,
			Parent = row,
		})
		newInst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = trackBg })

		local thumb = newInst("Frame", {
			BackgroundColor3 = Color3.fromRGB(160, 160, 160),
			BorderSizePixel = 0,
			Position = UDim2.new(0, 2, 0.5, -8),
			Size = UDim2.new(0, 16, 0, 16),
			ZIndex = 6,
			Parent = trackBg,
		})
		newInst("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumb })

		local function updateVisual(animated)
			local dur = animated and 0.25 or 0
			if state then
				tween(trackBg, { BackgroundColor3 = accentColor }, dur)
				tween(thumb, { Position = UDim2.new(0, 20, 0.5, -8), BackgroundColor3 = Color3.fromRGB(255, 255, 255) }, dur)
			else
				tween(trackBg, { BackgroundColor3 = Color3.fromRGB(50, 50, 50) }, dur)
				tween(thumb, { Position = UDim2.new(0, 2, 0.5, -8), BackgroundColor3 = Color3.fromRGB(160, 160, 160) }, dur)
			end
		end

		updateVisual(false)

		local clickArea = newInst("TextButton", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 1, 0),
			Text = "",
			ZIndex = 7,
			Parent = row,
		})
		clickArea.MouseButton1Click:Connect(function()
			state = not state
			updateVisual(true)
			callback(state)
		end)

		return {
			SetState = function(_, s)
				state = s
				updateVisual(true)
				callback(state)
			end,
			GetState = function() return state end,
		}
	end

