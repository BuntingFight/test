	self.content_area = new_inst("Frame", {
		Name = "content",
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 0, 0, 58),
		Size = UDim2.new(1, 0, 1, -58),
		ZIndex = 2,
		Parent = self.main_frame,
	})

	self.reopen_btn = new_inst("TextButton", {
		BackgroundColor3 = Color3.fromRGB(20, 20, 20),
		Size = UDim2.new(0, 40, 0, 40),
		Position = UDim2.new(0, 20, 1, -20),
		AnchorPoint = Vector2.new(0, 1),
		Font = Enum.Font.GothamBold,
		Text = "+",
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextSize = 18,
		Visible = false,
		BackgroundTransparency = 1,
		TextTransparency = 1,
		Parent = self.screen_gui,
	})
	new_inst("UICorner", { CornerRadius = UDim.new(0, 20), Parent = self.reopen_btn })
	new_inst("UIStroke", { Color = Color3.fromRGB(59, 130, 246), Thickness = 1, Parent = self.reopen_btn })

	local dragging, drag_start, start_pos = false, nil, nil
	header.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			drag_start = inp.Position
			start_pos = self.main_frame.Position
		end
	end)
	user_input_service.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = inp.Position - drag_start
			local target = UDim2.new(
				start_pos.X.Scale, start_pos.X.Offset + delta.X,
				start_pos.Y.Scale, start_pos.Y.Offset + delta.Y
			)
			tween(self.main_frame, { Position = target }, 0.07, Enum.EasingStyle.Linear)
		end
	end)
	user_input_service.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	local function perform_minimize()
		self.is_minimized = not self.is_minimized
		if self.is_minimized then
			tween(self.main_frame, { Size = UDim2.new(0, self.size.X.Offset, 0, 32) }, 0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
		else
			tween(self.main_frame, { Size = self.size }, 0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
		end
	end

	local function perform_close()
		if self.is_closed then return end
		self.is_closed = true
		local delay_time = 0
		if not self.is_minimized then
			tween(self.main_frame, { Size = UDim2.new(0, self.size.X.Offset, 0, 32) }, 0.3)
			delay_time = 0.35
		end
		task.delay(delay_time, function()
			tween(self.main_frame, { Position = UDim2.new(1.5, 0, self.main_frame.Position.Y.Scale, self.main_frame.Position.Y.Offset) }, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In)
			task.delay(0.4, function()
				self.main_frame.Visible = false
				self.reopen_btn.Visible = true
				tween(self.reopen_btn, { BackgroundTransparency = 0, TextTransparency = 0 }, 0.2)
			end)
		end)
	end

	local function perform_open()
		if not self.is_closed then return end
		self.is_closed = false
		tween(self.reopen_btn, { BackgroundTransparency = 1, TextTransparency = 1 }, 0.2)
		task.delay(0.2, function()
			self.reopen_btn.Visible = false
			self.main_frame.Visible = true
			tween(self.main_frame, { Position = UDim2.new(0.5, 0, 0.5, 0) }, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
			task.delay(0.4, function()
				self.is_minimized = false
				tween(self.main_frame, { Size = self.size }, 0.35)
			end)
		end)
	end

	min_btn.MouseButton1Click:Connect(perform_minimize)
	close_btn.MouseButton1Click:Connect(perform_close)
	self.reopen_btn.MouseButton1Click:Connect(perform_open)

	user_input_service.InputBegan:Connect(function(inp, proc)
		if proc then return end
		if inp.KeyCode == Enum.KeyCode.LeftShift or inp.KeyCode == Enum.KeyCode.RightShift then
			if self.is_closed then
				perform_open()
			else
				perform_close()
			end
		end
	end)

	self.main_frame.Size = UDim2.new(0, self.size.X.Offset * 0.9, 0, self.size.Y.Offset * 0.9)
	self.main_frame.BackgroundTransparency = 1
	self.stroke.Transparency = 1
	tween(self.main_frame, { Size = self.size, BackgroundTransparency = 0 }, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
	tween(self.stroke, { Transparency = 0 }, 0.4)

	return self
end

function window_mt:tab(opts)
	opts = opts or {}
	local name = opts.name or "tab"
	local tab_obj = { elements = {} }

	local tab_btn = new_inst("TextButton", {
		BackgroundColor3 = Color3.fromRGB(25, 25, 25),
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, -6),
		AutomaticSize = Enum.AutomaticSize.X,
		Font = Enum.Font.GothamSemibold,
		Text = "",
		ZIndex = 4,
		Parent = self.tab_scroll,
	})
	new_inst("UICorner", { CornerRadius = UDim.new(0, 6), Parent = tab_btn })
	new_inst("UIPadding", { PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), Parent = tab_btn })

	local tab_label = new_inst("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = name,
		TextColor3 = Color3.fromRGB(110, 110, 110),
		TextSize = 11,
		ZIndex = 5,
		Parent = tab_btn,
	})

	local page = new_inst("ScrollingFrame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0, 0),
		Size = UDim2.new(1, 0, 1, 0),
		CanvasSize = UDim2.new(0, 0, 0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		ScrollBarThickness = 2,
		ScrollBarImageColor3 = Color3.fromRGB(59, 130, 246),
		Visible = false,
		ZIndex = 3,
		Parent = self.content_area,
	})
	new_inst("UIPadding", {
		PaddingTop = UDim.new(0, 8),
		PaddingLeft = UDim.new(0, 8),
		PaddingRight = UDim.new(0, 8),
		PaddingBottom = UDim.new(0, 8),
		Parent = page,
	})

	local left_col = new_inst("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(0.5, -4, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Position = UDim2.new(0, 0, 0, 0),
		Parent = page
	})
	new_inst("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6), Parent = left_col })

	local right_col = new_inst("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(0.5, -4, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Position = UDim2.new(0.5, 4, 0, 0),
		Parent = page
	})
	new_inst("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6), Parent = right_col })

	tab_obj.btn = tab_btn
	tab_obj.label = tab_label
	tab_obj.page = page

	local function activate()
		for _, t in ipairs(self.tabs) do
			t.page.Visible = false
			tween(t.btn, { BackgroundColor3 = Color3.fromRGB(25, 25, 25) }, 0.2)
			tween(t.label, { TextColor3 = Color3.fromRGB(110, 110, 110) }, 0.2)
		end
		page.Visible = true
		tween(tab_btn, { BackgroundColor3 = Color3.fromRGB(35, 35, 35) }, 0.2)
		tween(tab_label, { TextColor3 = Color3.fromRGB(255, 255, 255) }, 0.2)
		self.active_tab = tab_obj
	end

	tab_btn.MouseButton1Click:Connect(activate)

	tab_btn.MouseEnter:Connect(function()
		if self.active_tab ~= tab_obj then
			tween(tab_btn, { BackgroundColor3 = Color3.fromRGB(30, 30, 30) }, 0.15)
			tween(tab_label, { TextColor3 = Color3.fromRGB(180, 180, 180) }, 0.15)
		end
	end)
	tab_btn.MouseLeave:Connect(function()
		if self.active_tab ~= tab_obj then
			tween(tab_btn, { BackgroundColor3 = Color3.fromRGB(25, 25, 25) }, 0.15)
			tween(tab_label, { TextColor3 = Color3.fromRGB(110, 110, 110) }, 0.15)
		end
	end)

	table.insert(self.tabs, tab_obj)

	if #self.tabs == 1 then
		activate()
	end

	function tab_obj:button(bopts)
		bopts = bopts or {}
		local bname = bopts.name or "button"
		local side = bopts.side or "left"
		local callback = bopts.callback or function() end
		local target_parent = side == "right" and right_col or left_col

		local row = new_inst("Frame", {
			BackgroundColor3 = Color3.fromRGB(25, 25, 25),
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 30),
			ZIndex = 4,
			Parent = target_parent,
		})
		new_inst("UICorner", { CornerRadius = UDim.new(0, 6), Parent = row })
		new_inst("UIStroke", { Color = Color3.fromRGB(40, 40, 40), Thickness = 1, Parent = row })

		local btn = new_inst("TextButton", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 1, 0),
			Font = Enum.Font.GothamSemibold,
			Text = bname,
			TextColor3 = Color3.fromRGB(220, 220, 220),
			TextSize = 11,
			ZIndex = 5,
			Parent = row,
		})

		btn.MouseEnter:Connect(function()
			tween(row, { BackgroundColor3 = Color3.fromRGB(32, 32, 32) }, 0.15)
		end)
		btn.MouseLeave:Connect(function()
			tween(row, { BackgroundColor3 = Color3.fromRGB(25, 25, 25) }, 0.15)
		end)
		btn.MouseButton1Down:Connect(function()
			tween(row, { BackgroundColor3 = Color3.fromRGB(18, 18, 18) }, 0.08)
		end)
		btn.MouseButton1Up:Connect(function()
			tween(row, { BackgroundColor3 = Color3.fromRGB(32, 32, 32) }, 0.15)
		end)
		btn.MouseButton1Click:Connect(function()
			callback()
		end)

		return row
	end

