local ui = {}
ui.__index = ui

local tween_service = game:GetService("TweenService")
local user_input_service = game:GetService("UserInputService")
local run_service = game:GetService("RunService")
local players = game:GetService("Players")
local local_player = players.LocalPlayer

local function tween(obj, props, dur, style, dir)
	style = style or Enum.EasingStyle.Quart
	dir = dir or Enum.EasingDirection.Out
	local t = tween_service:Create(obj, TweenInfo.new(dur, style, dir), props)
	t:Play()
	return t
end

local function new_inst(cls, props)
	local obj = Instance.new(cls)
	for k, v in pairs(props) do
		obj[k] = v
	end
	return obj
end

local function get_root_gui()
	local ok, cg = pcall(function() return game:GetService("CoreGui") end)
	if ok and cg then return cg end
	return local_player:WaitForChild("PlayerGui")
end

local notif_container = nil

local function ensure_notif_container()
	if notif_container and notif_container.Parent then return end
	local root = get_root_gui()
	local sg = new_inst("ScreenGui", {
		Name = "ui_notifs",
		ResetOnSpawn = false,
		DisplayOrder = 999,
		Parent = root,
	})
	notif_container = new_inst("Frame", {
		Name = "container",
		BackgroundTransparency = 1,
		Position = UDim2.new(1, -20, 1, -20),
		AnchorPoint = Vector2.new(1, 1),
		Size = UDim2.new(0, 320, 1, -20),
		Parent = sg,
	})
	new_inst("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		VerticalAlignment = Enum.VerticalAlignment.Bottom,
		Padding = UDim.new(0, 8),
		Parent = notif_container,
	})
end

function ui.notify(opts)
	opts = opts or {}
	local title = opts.title or "notify"
	local text = opts.text or ""
	local duration = opts.duration or 4
	local color = opts.color or Color3.fromRGB(59, 130, 246)

